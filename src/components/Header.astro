---
import { sanityClient } from 'sanity:client';
import { Phone, MessageSquare, ChevronDown, Menu, X } from 'lucide-react';
import Logo from './Logo.astro';

// Fetching Global Settings including our new Header Menu
const settings = await sanityClient.fetch(`*[_type == "siteSettings"][0]{
  ...,
  headerMenu[]
}`);

// Fetching Services for the dropdown
const services = (await sanityClient.fetch(`*[_type == "service"] | order(order asc)`)) || [];

// Safety check for navLinks
const navLinks = settings?.headerMenu || [];
---

<header class="sticky top-0 z-[100] bg-white border-b border-slate-100 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 md:px-6 h-16 md:h-20 flex items-center justify-between">
    <a href="/" class="hover:opacity-90 transition-opacity w-32 md:w-auto">
      <Logo />
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {
        navLinks.map((item) => (
          <a
            href={item.link}
            class="font-semibold text-slate-600 hover:text-blue-600 transition-colors"
          >
            {item.label}
          </a>
        ))
      }

      <div class="relative group py-4">
        <button
          class="font-semibold text-slate-600 group-hover:text-blue-600 flex items-center gap-1"
        >
          Services
          <ChevronDown size={14} />
        </button>

        <div
          class="absolute top-full -left-4 w-60 bg-white border border-slate-100 shadow-xl rounded-xl p-2 opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transition-all"
        >
          {
            services.map((s) => (
              <a
                href={`/services/${s.slug.current}`}
                class="block px-4 py-2 hover:bg-blue-50 rounded-lg font-medium text-slate-700 transition-colors"
              >
                {s.title}
              </a>
            ))
          }
        </div>
      </div>
    </nav>

    <div class="flex items-center gap-2 md:gap-4">
      <a
        href={`tel:${settings?.phone}`}
        class="hidden lg:flex items-center gap-2 font-bold text-slate-900"
      >
        <Phone size={18} class="text-blue-600" />
        {settings?.phone}
      </a>

      <a
        href={`https://wa.me/${settings?.whatsappNumber}`}
        class="hidden md:flex bg-green-600 text-white px-6 py-2.5 rounded-lg font-bold items-center gap-2 hover:bg-green-700 transition-colors shadow-lg shadow-green-100"
      >
        <MessageSquare size={18} />
        WhatsApp
      </a>

      <button class="md:hidden p-2 text-slate-600 relative z-[110]" id="mobile-menu-button">
        <Menu size={28} id="hamburger-icon" />
        <X size={28} id="close-icon" class="hidden" />
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="fixed inset-0 bg-white z-[105] translate-x-full transition-transform duration-300 md:hidden pt-24 px-6 overflow-y-auto"
  >
    <nav class="flex flex-col gap-6">
      {
        navLinks.map((item) => (
          <a href={item.link} class="text-2xl font-bold text-slate-900 border-b pb-4">
            {item.label}
          </a>
        ))
      }

      <div class="flex flex-col gap-4">
        <p class="text-xs font-black text-blue-600 uppercase tracking-widest">Our Services</p>
        <div class="grid grid-cols-1 gap-3">
          {
            services.map((s) => (
              <a
                href={`/services/${s.slug.current}`}
                class="text-lg font-semibold text-slate-700 pl-2 border-l-2 border-blue-100"
              >
                {s.title}
              </a>
            ))
          }
        </div>
      </div>
    </nav>
  </div>
</header>

<script>
  function initMenu() {
    const menuBtn = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    const hamburgerIcon = document.getElementById('hamburger-icon');
    const closeIcon = document.getElementById('close-icon');

    if (!menuBtn || !mobileMenu) return;

    menuBtn.addEventListener('click', () => {
      const isClosed = mobileMenu.classList.contains('translate-x-full');
      mobileMenu.classList.toggle('translate-x-full');
      hamburgerIcon?.classList.toggle('hidden');
      closeIcon?.classList.toggle('hidden');
      document.body.style.overflow = isClosed ? 'hidden' : '';
    });
  }

  initMenu();
  document.addEventListener('astro:after-swap', initMenu);
</script>
