---
import { sanityClient } from 'sanity:client';
import { MapPin, Phone, MessageSquare, ShieldCheck } from 'lucide-react';
import Logo from './Logo.astro';

const settings = await sanityClient.fetch(`*[_type == "siteSettings"][0]{
  ...,
  footerMenu[]
}`);

const services = (await sanityClient.fetch(`*[_type == "service"] | order(title asc)`)) || [];

const serviceAreas = settings?.mainServiceAreas || [];
const footerLinks = settings?.footerMenu || [];
---

<footer class="bg-slate-900 text-slate-400 pt-20 pb-10 border-t border-slate-800">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
    <div class="space-y-6">
      <div class="brightness-0 invert opacity-90 w-40">
        <Logo />
      </div>
      <p class="text-sm leading-relaxed max-w-xs">
        {settings?.description || `Professional door-to-door cargo services from UAE to Pakistan.`}
      </p>
      <div class="flex gap-4">
        <div
          class="flex items-center gap-2 text-xs font-bold text-white bg-slate-800 px-3 py-1.5 rounded-lg border border-slate-700"
        >
          <ShieldCheck size={14} class="text-blue-400" />
          Verified Business
        </div>
      </div>
    </div>

    <div>
      <h4 class="text-white font-bold mb-6 text-lg uppercase tracking-wider">Our Services</h4>
      <ul class="space-y-4 text-sm">
        {
          services.map((s) => (
            <li>
              <a
                href={`/services/${s.slug.current}`}
                class="hover:text-blue-400 transition-colors flex items-center gap-2"
              >
                <span class="w-1.5 h-1.5 rounded-full bg-blue-500/40" />
                {s.title}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h4 class="text-white font-bold mb-6 text-lg uppercase tracking-wider">Service Areas</h4>
      <div class="grid grid-cols-2 gap-4 text-xs">
        {
          serviceAreas.map((area) => (
            <div class="flex items-center gap-2 group">
              <MapPin
                size={12}
                class="text-slate-500 group-hover:text-blue-400 transition-colors"
              />
              <span class="group-hover:text-slate-200 transition-colors">{area}</span>
            </div>
          ))
        }
      </div>
      {serviceAreas.length === 0 && <p class="text-xs italic">All major cities in UAE</p>}
    </div>

    <div>
      <h4 class="text-white font-bold mb-6 text-lg uppercase tracking-wider">Contact & Support</h4>
      <ul class="space-y-4 text-sm mb-8">
        <li class="flex items-start gap-3">
          <Phone size={18} class="text-blue-500 mt-1" />
          <div>
            <p class="text-white font-bold">{settings?.phone}</p>
            <p class="text-[10px] text-slate-500 uppercase font-bold tracking-tighter">
              Direct Call
            </p>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <MessageSquare size={18} class="text-green-500 mt-1" />
          <a
            href={`https://wa.me/${settings?.whatsappNumber}`}
            class="hover:text-white transition-colors"
          >
            <p class="text-white font-bold">WhatsApp Support</p>
            <p class="text-[10px] text-slate-500 uppercase font-bold tracking-tighter">
              Instant Quote
            </p>
          </a>
        </li>
      </ul>

      <div class="pt-6 border-t border-slate-800">
        <p class="text-xs font-bold text-white mb-4">Quick Navigation</p>
        <div class="flex flex-wrap gap-x-4 gap-y-2 text-xs">
          {
            footerLinks.map((link) => (
              <a href={link.link} class="hover:text-blue-400 transition-colors">
                {link.label}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <div
    class="max-w-7xl mx-auto px-6 mt-16 pt-8 border-t border-slate-800 flex flex-col md:flex-row justify-between items-center gap-4 text-[10px] uppercase tracking-widest font-bold"
  >
    <p>© 2026 {settings?.businessName || 'Logistics'}. All Rights Reserved.</p>
    <div class="flex gap-8">
      <a href="/privacy-policy" class="hover:text-white">Privacy</a>
      <a href="/terms-conditions" class="hover:text-white">Terms</a>
      <a href="/sitemap.xml" class="hover:text-white">Sitemap</a>
    </div>
  </div>
</footer>
