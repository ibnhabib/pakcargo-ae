---
import { sanityClient } from "sanity:client";
import { MapPin, Mail, Phone, Ship } from 'lucide-react';

const settings = await sanityClient.fetch(`*[_type == "siteSettings"][0]`);
const services = await sanityClient.fetch(`*[_type == "service"] | order(title asc)`);
const serviceAreas = settings?.mainServiceAreas || [];
---

<footer class="bg-slate-950 text-slate-400 pt-20 pb-10 border-t border-white/5">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-20">
    
    <div class="space-y-6">
      <div class="flex items-center gap-2">
        <Ship class="text-blue-500" size={25} />
        <span class="text-2xl font-black text-white tracking-tighter">PakCargo<span class="text-blue-600">.ae</span></span>
      </div>
      <p class="text-sm leading-relaxed">
        The UAE's most trusted partner for door-to-door cargo to Pakistan. Moving your items with safety and speed since 2026.
      </p>
      <div class="flex gap-4">
        {settings?.socialLinks?.map((link: string) => (
          <a href={link} class="w-10 h-10 bg-white/5 rounded-xl flex items-center justify-center hover:bg-blue-600 hover:text-white transition-all italic font-bold">L</a>
        ))}
      </div>
    </div>

    <div>
      <h4 class="text-white font-bold mb-6">Our Services</h4>
      <ul class="space-y-4 text-sm">
        {services.map((s) => (
          <li><a href={`/services/${s.slug.current}`} class="hover:text-blue-400 transition-colors">{s.title} to Pakistan</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h4 class="text-white font-bold mb-6">Service Areas</h4>
      <ul class="grid grid-cols-2 gap-x-4 gap-y-4 text-xs">
        {serviceAreas.map((area) => (
          <li class="flex items-center gap-2">
            <MapPin size={12} class="text-blue-500" />
            <span>Cargo in {area}</span>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <h4 class="text-white font-bold mb-6">Contact Us</h4>
      <ul class="space-y-4 text-sm">
        <li class="flex items-center gap-3">
          <Phone size={18} class="text-blue-500" />
          <span class="text-white font-bold">{settings?.phone}</span>
        </li>
        <li class="flex items-center gap-3 italic">
          <MapPin size={18} class="text-blue-500" />
          <span>{settings?.address || 'Dubai, United Arab Emirates'}</span>
        </li>
      </ul>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6 pt-10 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4 text-xs">
    <p>© 2026 PakCargo.ae - All Rights Reserved.</p>
    <div class="flex gap-6">
      <a href="/privacy" class="hover:text-white">Privacy Policy</a>
      <a href="/terms" class="hover:text-white">Terms of Service</a>
    </div>
  </div>
</footer>
