---
const { trustData } = Astro.props;
import { Trophy, Truck, ShieldCheck, Warehouse } from 'lucide-react';

const iconMap = {
  trophy: Trophy,
  truck: Truck,
  shield: ShieldCheck,
  warehouse: Warehouse
};
---

<section class="py-24 bg-slate-900 text-white relative overflow-hidden">
  {/* Decorative Background Elements */}
  <div class="absolute top-0 right-0 w-1/2 h-full bg-blue-600/10 skew-x-12 translate-x-1/4"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="grid lg:grid-cols-2 gap-20 items-center">
      
      <div>
        <h2 class="text-blue-400 font-bold uppercase tracking-widest text-sm mb-6">{trustData.title}</h2>
        <p class="text-4xl md:text-5xl font-black mb-8 leading-tight">
          Reliable Logistics <span class="text-blue-500 italic">Proven</span> by Experience
        </p>
        <p class="text-slate-400 text-lg mb-12 max-w-lg">
          {trustData.subtitle}
        </p>

        {/* FACT-BASED STATS GRID */}
        <div class="grid grid-cols-2 gap-8">
          <div class="p-6 bg-white/5 rounded-3xl border border-white/10 hover:border-blue-500/50 transition-colors">
            <p class="text-blue-400 font-black text-3xl mb-1">{trustData.shipmentsCount}</p>
            <p class="text-slate-400 text-sm font-bold uppercase tracking-tighter">Shipments Delivered</p>
          </div>
          <div class="p-6 bg-white/5 rounded-3xl border border-white/10 hover:border-blue-500/50 transition-colors">
            <p class="text-blue-400 font-black text-3xl mb-1">{trustData.experienceYears}</p>
            <p class="text-slate-400 text-sm font-bold uppercase tracking-tighter">Market Experience</p>
          </div>
          <div class="p-6 bg-white/5 rounded-3xl border border-white/10 hover:border-blue-500/50 transition-colors">
            <p class="text-blue-400 font-black text-3xl mb-1">{trustData.warehouseSize}</p>
            <p class="text-slate-400 text-sm font-bold uppercase tracking-tighter">Warehouse Capacity</p>
          </div>
          <div class="p-6 bg-white/5 rounded-3xl border border-white/10 hover:border-blue-500/50 transition-colors">
            <p class="text-blue-400 font-black text-3xl mb-1">{trustData.safeDeliveryRate}</p>
            <p class="text-slate-400 text-sm font-bold uppercase tracking-tighter">Safety Record</p>
          </div>
        </div>
      </div>

      <div class="grid gap-6">
        {trustData.points.map((point) => {
          const Icon = iconMap[point.icon] || ShieldCheck;
          return (
            <div class="flex gap-6 p-8 bg-white/5 rounded-[2rem] border border-white/10 hover:bg-white/10 transition-all group">
              <div class="flex-shrink-0 w-14 h-14 bg-blue-600 rounded-2xl flex items-center justify-center text-white group-hover:scale-110 transition-transform">
                <Icon size={28} />
              </div>
              <div>
                <h3 class="text-xl font-bold mb-2">{point.heading}</h3>
                <p class="text-slate-400 text-sm leading-relaxed">{point.description}</p>
              </div>
            </div>
          )
        })}
      </div>

    </div>
  </div>
</section>
