---
import { sanityClient } from 'sanity:client';
import { urlFor } from '../lib/sanity';
import { Calendar, ArrowRight } from 'lucide-react';

// Fetch blogs ordered by manual 'order' first, then by 'publishedAt' date
const posts = await sanityClient.fetch(`
  *[_type == "post"] | order(order asc, publishedAt desc)[0...3] {
    title,
    slug,
    mainImage,
    publishedAt,
    metaDescription,
    "category": categories[0]->title
  }
`);
---

<section class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
      <div class="max-w-2xl">
        <h2 class="text-blue-600 font-bold uppercase tracking-widest text-sm mb-4">
          Expert Logistics Guides
        </h2>
        <p
          class="text-4xl md:text-6xl font-black text-slate-900 leading-tight italic tracking-tighter"
        >
          Mastering <span class="text-blue-600">Cargo to Pakistan</span>
        </p>
      </div>
      <a
        href="/blog"
        class="group flex items-center gap-2 font-bold text-slate-900 hover:text-blue-600 transition-all text-lg"
      >
        View All Guides
        <ArrowRight class="group-hover:translate-x-2 transition-transform" />
      </a>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {
        posts.map((post) => (
          <article class="group relative flex flex-col bg-slate-50 rounded-[2.5rem] p-5 border border-slate-100 hover:border-blue-200 hover:bg-white hover:shadow-[0_30px_60px_-15px_rgba(0,0,0,0.1)] transition-all duration-500">
            <div class="relative aspect-[4/3] rounded-[1.5rem] overflow-hidden mb-6 shadow-sm">
              {post.mainImage && (
                <img
                  src={urlFor(post.mainImage).width(600).height(450).url()}
                  alt={post.mainImage.alt || post.title}
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                />
              )}
              {post.category && (
                <div class="absolute top-4 left-4">
                  <span class="px-3 py-1 bg-white/90 backdrop-blur-md text-blue-600 text-[10px] font-black uppercase rounded-lg shadow-sm">
                    {post.category}
                  </span>
                </div>
              )}
            </div>

            <div class="px-2 pb-2 flex flex-col flex-grow">
              <div class="flex items-center gap-2 text-slate-400 text-xs font-bold uppercase tracking-wide mb-3">
                <Calendar size={14} class="text-blue-500" />
                {new Date(post.publishedAt).toLocaleDateString('en-AE', {
                  month: 'long',
                  year: 'numeric',
                })}
              </div>

              <h3 class="text-2xl font-black text-slate-900 mb-4 line-clamp-2 leading-tight group-hover:text-blue-600 transition-colors">
                <a href={`/blog/${post.slug.current}`}>
                  <span class="absolute inset-0" />
                  {post.title}
                </a>
              </h3>

              <p class="text-slate-600 text-sm leading-relaxed line-clamp-2 mb-6">
                {post.metaDescription ||
                  'Expert advice and latest updates on shipping electronics, household goods, and commercial cargo from UAE.'}
              </p>

              <div class="mt-auto flex items-center text-blue-600 font-black text-sm uppercase tracking-wider">
                Read Full Guide
                <ArrowRight size={18} class="ml-2 group-hover:translate-x-2 transition-transform" />
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
