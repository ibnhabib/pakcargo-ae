---
const { rates } = Astro.props;
---

<section class="max-w-5xl mx-auto py-12 px-4">
  <div class="text-center mb-10">
    <h2 class="text-3xl font-bold text-slate-900 mb-2 text-blue-700">Official Shipping Rates</h2>
    <p class="text-slate-600">Flat rates from UAE to all cities in Pakistan. No hidden charges.</p>
  </div>

  <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    {rates.map((item) => (
      <div class="bg-white rounded-2xl shadow-lg border border-slate-100 overflow-hidden hover:shadow-xl transition-shadow">
        <div class="bg-blue-600 p-4 text-white">
          <h3 class="font-bold text-lg uppercase tracking-wide">{item.cargoType}</h3>
        </div>

        <div class="p-6 text-center">
          <div class="flex items-center justify-center mb-2">
            <span class="text-sm font-bold text-slate-400 mr-1 uppercase">AED</span>
            <span class="text-5xl font-black text-slate-800">{item.pricePerKg}</span>
            <span class="text-lg font-bold text-slate-400 ml-1">/KG</span>
          </div>
          
          <div class="inline-block px-3 py-1 bg-blue-50 text-blue-700 text-xs font-bold rounded-full mb-4">
            {item.minWeight || "Standard Rates Apply"}
          </div>

          <p class="text-slate-500 text-sm leading-relaxed mb-6">
            {item.notes || "Door-to-door delivery included with customs clearing."}
          </p>

          <button class="w-full py-3 bg-slate-900 text-white font-bold rounded-xl hover:bg-blue-700 transition-colors">
            Book This Service
          </button>
        </div>
      </div>
    ))}
  </div>

  <div class="mt-8 text-center text-slate-400 text-xs">
    *Terms and conditions apply. Prices are subject to volume and item category.
  </div>
</section>