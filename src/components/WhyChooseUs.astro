---
const { data } = Astro.props;
import { BadgeDollarSign, PackageCheck, MapPin, ShieldCheck, Truck, Clock } from 'lucide-react';

const iconMap = {
  dollar: BadgeDollarSign,
  package: PackageCheck,
  map: MapPin,
  shield: ShieldCheck,
  truck: Truck,
  clock: Clock
};
---

<section class="py-24 bg-blue-900 text-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">
    {data ? (
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-4xl font-bold mb-6">{data?.title || "Why Choose Us"}</h2>
          <p class="text-blue-100 text-lg mb-10">{data?.subtitle}</p>

          <div class="space-y-8">
            {data?.points?.map((point) => {
              const IconComponent = iconMap[point.icon] || PackageCheck;
              return (
                <div class="flex gap-6">
                  <div class="flex-shrink-0 w-12 h-12 bg-blue-700 rounded-lg flex items-center justify-center">
                    <IconComponent size={28} class="text-yellow-400" />
                  </div>
                  <div>
                    <h3 class="text-xl font-bold mb-2">{point.heading}</h3>
                    <p class="text-blue-200">{point.description}</p>
                  </div>
                </div>
              );
            })}
          </div>
        </div>

        <div class="relative hidden lg:block">
          <div class="bg-blue-800 rounded-3xl p-8 border border-blue-700 shadow-2xl">
            <div class="flex items-center gap-4 mb-6 border-b border-blue-700 pb-6">
              <div class="bg-green-500 w-3 h-3 rounded-full animate-pulse"></div>
              <p class="text-sm font-mono uppercase tracking-widest text-blue-300">Live Operation Status</p>
            </div>
            <div class="space-y-4">
               <div class="bg-blue-900/50 p-4 rounded-xl flex justify-between">
                  <span class="text-blue-100">Monthly Shipments</span>
                  <span class="font-bold text-yellow-400">{data?.shipmentsCount}</span>
               </div>
               <div class="bg-blue-900/50 p-4 rounded-xl flex justify-between">
                  <span class="text-blue-100">Customer Satisfaction</span>
                  <span class="font-bold text-yellow-400">{data?.satisfactionRate}</span>
               </div>
               <div class="bg-blue-900/50 p-4 rounded-xl flex justify-between">
                  <span class="text-blue-100">Average Delivery</span>
                  <span class="font-bold text-yellow-400">{data?.deliveryTime}</span>
               </div>
            </div>
          </div>
        </div>
      </div>
    ) : (
      <p class="text-center text-blue-300 italic">Trust points content coming soon...</p>
    )}
  </div>
</section>