---
import { PortableText as PortableTextInternal } from 'astro-portabletext';
import { urlFor } from '../lib/sanity';
import { AlertTriangle } from 'lucide-react';

const { value } = Astro.props;

const components = {
  type: {
    image: ({ node }: any) => {
      // Automatically optimize width for performance
      const imageUrl = urlFor(node).width(1200).auto('format').url();
      return {
        template: `
          <figure class="my-10 overflow-hidden rounded-3xl border border-slate-200 shadow-xl">
            <img 
              src="${imageUrl}" 
              alt="${node.alt || 'Pakistan Cargo Logistics Details'}" 
              loading="lazy"
              class="w-full h-auto object-cover"
            />
            ${node.alt ? `<figcaption class="bg-slate-50 px-6 py-3 text-sm text-slate-500 italic border-t border-slate-100 font-medium">${node.alt}</figcaption>` : ''}
          </figure>
        `,
      };
    },
  },
  block: {
    // H4 is your "Customs Alert" - Perfect for Logistics Monopoly
    h4: ({ children }: any) => `
      <div class="my-8 p-6 bg-red-50 border-l-[12px] border-red-600 rounded-r-3xl shadow-md">
        <div class="flex items-center gap-3 text-red-700 mb-2">
          <span class="p-1 bg-red-600 rounded-full text-white">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
          </span>
          <strong class="text-lg uppercase tracking-widest font-black">Important Customs Notice</strong>
        </div>
        <div class="text-red-900 font-semibold leading-relaxed pl-10">
          ${children}
        </div>
      </div>`,

    h2: ({ children }: any) =>
      `<h2 class="text-3xl md:text-4xl font-black text-slate-900 mt-16 mb-6 tracking-tight flex items-center gap-3">
        <span class="w-8 h-1 bg-blue-600 rounded-full"></span>
        ${children}
      </h2>`,

    h3: ({ children }: any) =>
      `<h3 class="text-2xl font-bold text-slate-800 mt-10 mb-4 pl-4 border-l-4 border-slate-200">${children}</h3>`,

    blockquote: ({ children }: any) =>
      `<blockquote class="border-l-8 border-blue-600 pl-8 my-10 py-4 bg-blue-50/80 rounded-r-3xl text-slate-800 italic text-2xl font-medium leading-snug">
        ${children}
      </blockquote>`,

    normal: ({ children }: any) => `<p class="text-slate-600 leading-[1.8] mb-6">${children}</p>`,
  },
  list: {
    bullet: ({ children }: any) =>
      `<ul class="list-disc list-outside ml-6 space-y-3 mb-8 text-slate-600">${children}</ul>`,
    number: ({ children }: any) =>
      `<ol class="list-decimal list-outside ml-6 space-y-3 mb-8 text-slate-600">${children}</ol>`,
  },
};
---

<div
  class="prose prose-lg prose-slate max-w-none
  prose-headings:font-black prose-headings:text-slate-900
  prose-p:text-slate-600 prose-p:leading-relaxed
  prose-strong:text-blue-700 prose-strong:font-bold
  prose-a:text-blue-600 prose-a:font-bold prose-a:no-underline hover:prose-a:underline
  prose-li:marker:text-blue-500"
>
  <PortableTextInternal value={value} components={components} />
</div>
