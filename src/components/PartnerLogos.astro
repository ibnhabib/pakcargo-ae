---
import { urlFor } from '../lib/sanity';
const { globalPartners, localPartners } = Astro.props;
---

<section class="py-12 md:py-16 bg-white border-t border-slate-100">
  <div class="max-w-7xl mx-auto px-6 text-center">
    
    {globalPartners?.length > 0 && (
      <div class="mb-16 md:mb-20">
        <h3 class="text-lg md:text-xl font-bold text-slate-900 mb-2">Global Express Partners</h3>
        <p class="text-sm md:text-base text-slate-500 mb-8 md:mb-10 max-w-2xl mx-auto">
          Fast document and parcel services from UAE via premium air express.
        </p>
        
        <div class="flex flex-wrap justify-center items-center gap-x-8 gap-y-10 md:gap-20">
          {globalPartners.map(partner => (
            <img 
              src={urlFor(partner.logo).width(300).url()} 
              alt={`${partner.name} - Official Global Shipping Partner`} 
              class="h-8 md:h-12 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300" 
            />
          ))}
        </div>
      </div>
    )}

    {localPartners?.length > 0 && (
      <div>
        <h3 class="text-lg md:text-xl font-bold text-slate-900 mb-2">Pakistan Last-Mile Network</h3>
        <p class="text-sm md:text-base text-slate-500 mb-8 md:mb-10 max-w-2xl mx-auto">
          Nationwide delivery from our Karachi hub to every city and village.
        </p>
        
        <div class="flex flex-wrap justify-center items-center gap-x-8 gap-y-10 md:gap-20">
          {localPartners.map(partner => (
            <img 
              src={urlFor(partner.logo).width(300).url()} 
              alt={`${partner.name} - Pakistan Domestic Delivery Partner`} 
              class="h-8 md:h-12 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300" 
            />
          ))}
        </div>
      </div>
    )}

  </div>
</section>