---
import '../styles/global.css';
import { sanityClient } from 'sanity:client';
import { urlFor } from '../lib/sanity';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingActions from '../components/FloatingActions.astro';
import LocalBusinessSchema from '../components/LocalBusinessSchema.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: any;
  canonicalUrl?: string;
}

const { title, description, ogImage, canonicalUrl } = Astro.props;

// 1. Fetching Global Settings - This makes the layout "Domain-Agnostic"
const settings = await sanityClient.fetch(`*[_type == "siteSettings"][0]{
  title,
  description,
  siteUrl,
  gtmId,
  gaId,
  siteVerificationCode,
  semrushCode,
  businessName,
  legalName,
  address,
  geoCoordinates,
  phone,
  whatsappNumber,
  tradeLicense,
  openingHours,
  socialLinks
}`);

// 2. Logic to handle fallbacks for SEO
const siteBrand = settings?.businessName || 'PakCargo';
const finalTitle = title
  ? `${title} | ${siteBrand}`
  : settings?.title || `${siteBrand} | Logistics Services`;
const finalDesc =
  description ||
  settings?.description ||
  `Professional cargo and shipping services from UAE to Pakistan.`;

// 3. Dynamic Canonical URL - Automatically adapts to whatever domain you are on
const baseDomain = settings?.siteUrl || 'https://cargotopakistan.ae';
const currentCanonical = canonicalUrl || `${baseDomain}${Astro.url.pathname}`;
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{finalTitle}</title>
    <meta name="description" content={finalDesc} />
    <link rel="canonical" href={currentCanonical} />

    {
      settings?.siteVerificationCode && (
        <meta name="google-site-verification" content={settings.siteVerificationCode} />
      )
    }
    {
      settings?.semrushCode && (
        <meta name="semrush-site-verification" content={settings.semrushCode} />
      )
    }

    <meta property="og:title" content={finalTitle} />
    <meta property="og:description" content={finalDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={currentCanonical} />
    {ogImage && <meta property="og:image" content={urlFor(ogImage).width(1200).url()} />}

    <LocalBusinessSchema settings={settings} />

    {
      settings?.gtmId && (
        <script
          is:inline
          set:html={`
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','${settings.gtmId}');
      `}
        />
      )
    }
  </head>

  <body class="bg-white min-h-screen font-sans antialiased overflow-x-hidden flex flex-col">
    {
      settings?.gtmId && (
        <noscript>
          <iframe
            src={`https://www.googletagmanager.com/ns.html?id=${settings.gtmId}`}
            height="0"
            width="0"
            style="display:none;visibility:hidden"
          />
        </noscript>
      )
    }

    <Header />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer />
    <FloatingActions />
  </body>
</html>
