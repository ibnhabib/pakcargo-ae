---
import { sanityClient } from 'sanity:client';
import Layout from '../layouts/Layout.astro';
import PortableText from '../components/PortableText.astro';
import { Table, MapPin, CheckCircle2 } from 'lucide-react';

export async function getStaticPaths() {
  // Fetch both 'page' and 'service' types to generate all URLs
  const data = await sanityClient.fetch(`*[_type in ["page", "service"]]`);

  return data.map((item: any) => ({
    params: { slug: item.slug.current },
    props: { item },
  }));
}

const { item } = Astro.props;

if (!item) {
  return Astro.redirect('/404');
}

// Logic to determine if this is a Service page or a standard Page
const isService = item._type === 'service';
---

<Layout
  title={item.seoTitle || item.title}
  description={item.metaDescription || item.description}
  keywords={item.keywords}
>
  <main class="relative pt-32 pb-20 bg-slate-50 min-h-screen">
    <div class="max-w-5xl mx-auto px-6">
      <header class="mb-12">
        <div
          class="flex items-center gap-3 text-blue-600 font-bold mb-4 uppercase tracking-widest text-sm"
        >
          <span class="px-3 py-1 bg-blue-100 rounded-lg"
            >{isService ? 'Service' : 'Information'}</span
          >
          {item.startingPrice && <span>• Starting from AED {item.startingPrice}</span>}
        </div>
        <h1 class="text-4xl md:text-7xl font-black text-slate-900 mb-6 tracking-tight leading-none">
          {item.title}
        </h1>
        <p class="text-xl text-slate-600 max-w-2xl leading-relaxed">
          {item.description}
        </p>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2 space-y-12">
          <article
            class="bg-white p-8 md:p-12 rounded-[2.5rem] shadow-sm border border-slate-100 prose prose-slate prose-lg max-w-none"
          >
            <PortableText value={item.details || item.content} />
          </article>

          {
            isService && item.rateTable && (
              <section class="bg-slate-900 rounded-[2.5rem] p-8 md:p-12 text-white shadow-2xl">
                <div class="flex items-center gap-4 mb-8">
                  <Table class="text-blue-400" size={32} />
                  <h2 class="text-3xl font-black italic">Latest Shipping Rates</h2>
                </div>
                <div class="overflow-x-auto">
                  <table class="w-full text-left border-collapse">
                    <thead>
                      <tr class="border-b border-slate-700 text-slate-400 uppercase text-sm tracking-wider">
                        <th class="py-4 px-2">Item/Category</th>
                        <th class="py-4 px-2">Unit</th>
                        <th class="py-4 px-2">Price (AED)</th>
                      </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-800">
                      {item.rateTable.map((row: any) => (
                        <tr class="hover:bg-slate-800/50 transition-colors">
                          <td class="py-5 px-2 font-bold">{row.item}</td>
                          <td class="py-5 px-2 text-slate-400">{row.unit}</td>
                          <td class="py-5 px-2 text-blue-400 font-black">AED {row.price}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
                {item.rateTable[0]?.note && (
                  <p class="mt-6 text-sm text-slate-500 italic">* {item.rateTable[0].note}</p>
                )}
              </section>
            )
          }
        </div>

        <div class="space-y-8">
          {
            isService && item.keyFeatures && (
              <div class="bg-white p-8 rounded-[2rem] border border-slate-200 shadow-sm">
                <h3 class="text-xl font-black mb-6 flex items-center gap-2">
                  <CheckCircle2 class="text-green-500" /> Key Features
                </h3>
                <ul class="space-y-4">
                  {item.keyFeatures.map((feature: string) => (
                    <li class="flex items-start gap-3 text-slate-600 font-medium leading-tight">
                      <span class="h-2 w-2 mt-1.5 rounded-full bg-blue-600 shrink-0" />
                      {feature}
                    </li>
                  ))}
                </ul>
              </div>
            )
          }

          {
            isService && item.serviceableAreas && (
              <div class="bg-blue-50 p-8 rounded-[2rem] border border-blue-100">
                <h3 class="text-xl font-black text-blue-900 mb-6 flex items-center gap-2">
                  <MapPin /> Service Areas
                </h3>
                <div class="flex flex-wrap gap-2">
                  {item.serviceableAreas.map((area: string) => (
                    <span class="px-4 py-2 bg-white text-blue-700 text-sm font-bold rounded-xl border border-blue-200">
                      {area}
                    </span>
                  ))}
                </div>
              </div>
            )
          }

          <div class="bg-slate-900 p-8 rounded-[2rem] text-center text-white">
            <h3 class="text-2xl font-black mb-4">Need a Quote?</h3>
            <p class="text-slate-400 mb-6">Fast & secure shipping to Pakistan.</p>
            <a
              href="/contact"
              class="block w-full py-4 bg-blue-600 hover:bg-blue-700 rounded-2xl font-black transition-all"
            >
              Contact Us Now
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>
