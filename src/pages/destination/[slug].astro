---
import { sanityClient } from 'sanity:client';
import Layout from '../../layouts/Layout.astro';
import { MapPin, Clock, ShieldCheck, Box, Truck, CheckCircle2 } from 'lucide-react';

export async function getStaticPaths() {
  // Define your main Pakistan Destination Hubs
  const destinations = [
    {
      slug: 'lahore',
      name: 'Lahore',
      province: 'Punjab',
      timeline: '25-35 Days (Sea) / 5-7 Days (Air)',
      coverage: ['Gujranwala', 'Sialkot', 'Sheikhupura', 'Kasur', 'Okara'],
      customsHub: 'Lahore Dry Port',
    },
    {
      slug: 'karachi',
      name: 'Karachi',
      province: 'Sindh',
      timeline: '20-25 Days (Sea) / 3-5 Days (Air)',
      coverage: ['Hyderabad', 'Sukkur', 'Port Qasim', 'SITE Area'],
      customsHub: 'Karachi Port / KPT',
    },
    {
      slug: 'islamabad',
      name: 'Islamabad & Rawalpindi',
      province: 'Punjab/KPK',
      timeline: '28-38 Days (Sea) / 5-8 Days (Air)',
      coverage: ['Peshawar', 'Abbottabad', 'Mardan', 'Jhelum', 'Chakwal'],
      customsHub: 'Islamabad Local Terminal',
    },
  ];

  return destinations.map((dest) => ({
    params: { slug: dest.slug },
    props: { dest },
  }));
}

const { dest } = Astro.props;
const settings = await sanityClient.fetch(`*[_type == "siteSettings"][0]`);

const destinationSchema = {
  '@context': 'https://schema.org',
  '@type': 'DeliveryEvent',
  name: `Cargo Delivery to ${dest.name}, Pakistan`,
  description: `Door-to-door cargo delivery services from UAE to ${dest.name} and surrounding areas in ${dest.province}.`,
  areaServed: {
    '@type': 'City',
    name: dest.name,
    containedInPlace: { '@type': 'Country', name: 'Pakistan' },
  },
};
---

<Layout
  title={`Cargo to ${dest.name} from UAE | Door to Door Delivery`}
  description={`Send cargo from Dubai/Abu Dhabi to ${dest.name}. Reliable shipping with customs clearance at ${dest.customsHub}. Covering ${dest.coverage.join(', ')}.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(destinationSchema)} slot="head" />

  <main class="bg-slate-50">
    <section class="bg-blue-900 py-24 relative overflow-hidden">
      <div
        class="absolute right-0 top-0 w-1/3 h-full bg-blue-800/20 skew-x-12 transform translate-x-20"
      >
      </div>
      <div class="max-w-6xl mx-auto px-6 relative z-10">
        <span
          class="inline-block px-4 py-1 bg-blue-500/30 rounded-full text-blue-200 text-sm font-bold mb-6 backdrop-blur-sm"
        >
          Destination Hub: {dest.province} Region
        </span>
        <h1 class="text-4xl md:text-7xl font-black text-white mb-6">
          Door-to-Door Cargo <br /><span class="text-blue-400 font-serif italic"
            >to {dest.name}</span
          >
        </h1>
        <p class="text-blue-100 text-lg max-w-2xl leading-relaxed">
          Our specialized logistics network ensures your goods reach {dest.name} safely. We handle everything
          from UAE collection to Pakistan customs clearance and final doorstep delivery.
        </p>
      </div>
    </section>

    <div class="max-w-6xl mx-auto px-6 -mt-12 pb-24">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2 space-y-8">
          <div class="bg-white p-8 md:p-12 rounded-[2.5rem] shadow-xl border border-slate-100">
            <h2 class="text-3xl font-black text-slate-900 mb-8 italic">Delivery Timelines</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="p-6 bg-slate-50 rounded-3xl border border-slate-100">
                <div class="flex items-center gap-3 mb-4 text-blue-600">
                  <Clock size={24} />
                  <span class="font-black uppercase tracking-widest text-xs">Estimated Time</span>
                </div>
                <p class="text-2xl font-bold text-slate-900">{dest.timeline}</p>
                <p class="text-sm text-slate-500 mt-2">
                  Includes customs processing time at {dest.customsHub}.
                </p>
              </div>
              <div class="p-6 bg-slate-50 rounded-3xl border border-slate-100">
                <div class="flex items-center gap-3 mb-4 text-green-600">
                  <ShieldCheck size={24} />
                  <span class="font-black uppercase tracking-widest text-xs">Service Status</span>
                </div>
                <p class="text-2xl font-bold text-slate-900">Active & Secure</p>
                <p class="text-sm text-slate-500 mt-2">
                  Weekly container departures from Jebel Ali Port.
                </p>
              </div>
            </div>
          </div>

          <div class="bg-white p-8 md:p-12 rounded-[2.5rem] shadow-sm border border-slate-100">
            <h2 class="text-3xl font-black text-slate-900 mb-6 italic">
              Surrounding Areas Covered
            </h2>
            <p class="text-slate-600 mb-8">
              Using our {dest.name} hub, we provide daily delivery services to the following districts:
            </p>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
              {
                dest.coverage.map((area) => (
                  <div class="flex items-center gap-3 p-4 bg-slate-50 rounded-2xl border border-slate-100">
                    <CheckCircle2 size={18} class="text-blue-500 shrink-0" />
                    <span class="font-bold text-slate-800 text-sm">{area}</span>
                  </div>
                ))
              }
            </div>
          </div>
        </div>

        <div class="space-y-6">
          <div
            class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-100 sticky top-24"
          >
            <div
              class="w-16 h-16 bg-blue-100 rounded-2xl flex items-center justify-center text-blue-600 mb-6"
            >
              <Box size={32} />
            </div>
            <h3 class="text-2xl font-bold text-slate-900 mb-4">Request Rates to {dest.name}</h3>
            <p class="text-slate-600 mb-8 text-sm leading-relaxed">
              Get city-specific rates for electronics, household items, or commercial cargo moving
              to {dest.province}.
            </p>
            <div class="space-y-3">
              <a
                href={`https://wa.me/${settings?.whatsappNumber}?text=Hi, I want to ship to ${dest.name}.`}
                class="flex items-center justify-center gap-2 w-full py-4 bg-green-600 text-white font-bold rounded-2xl hover:bg-green-700 transition-all"
              >
                WhatsApp Quote
              </a>
              <a
                href={`tel:${settings?.phone}`}
                class="flex items-center justify-center gap-2 w-full py-4 bg-slate-900 text-white font-bold rounded-2xl hover:bg-black transition-all"
              >
                Call Support
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>
