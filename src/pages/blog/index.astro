---
import { sanityClient } from 'sanity:client';
import Layout from '../../layouts/Layout.astro';
import { urlFor } from '../../lib/sanity';

// 1. Fetch all blog posts from Sanity (Ordered by Date)
const posts = await sanityClient.fetch(`
  *[_type == "post"] | order(publishedAt desc) {
    title,
    slug,
    mainImage,
    publishedAt,
    metaDescription,
    "authorName": author->name
  }
`);

// 2. Identify the "Featured Post" (the most recent one)
const featuredPost = posts[0];
const remainingPosts = posts.slice(1);
---

<Layout
  title="Logistics & Shipping Blog | PakCargo.ae UAE"
  description="Expert guides on sea and air cargo from Dubai, Abu Dhabi, and Sharjah to Pakistan. Get the latest shipping rates and customs advice."
>
  <section class="bg-slate-50 py-20">
    <div class="max-w-7xl mx-auto px-6">
      <div class="mb-16 text-center max-w-3xl mx-auto">
        <h1 class="text-4xl md:text-6xl font-extrabold text-slate-900 mb-6 tracking-tight">
          Shipping <span class="text-blue-600">Insights</span>
        </h1>
        <p class="text-lg text-slate-600 leading-relaxed">
          Stay updated with the latest cargo rates, customs regulations, and door-to-door delivery
          guides for the UAE to Pakistan corridor.
        </p>
      </div>

      {
        featuredPost && (
          <a
            href={`/blog/${featuredPost.slug.current}`}
            class="group relative block mb-20 bg-white rounded-[2.5rem] overflow-hidden shadow-xl hover:shadow-2xl transition-all border border-slate-100"
          >
            <div class="grid lg:grid-cols-2 items-center">
              <div class="aspect-[16/10] overflow-hidden">
                <img
                  src={urlFor(featuredPost.mainImage).width(1000).height(700).url()}
                  alt={featuredPost.mainImage.alt}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                />
              </div>
              <div class="p-8 md:p-12 lg:p-16">
                <span class="inline-block px-4 py-2 bg-blue-100 text-blue-700 text-xs font-bold rounded-full uppercase tracking-widest mb-6">
                  Featured Guide
                </span>
                <h2 class="text-3xl md:text-4xl font-black text-slate-900 mb-6 group-hover:text-blue-600 transition-colors">
                  {featuredPost.title}
                </h2>
                <p class="text-slate-600 text-lg mb-8 line-clamp-3">
                  {featuredPost.metaDescription}
                </p>
                <div class="flex items-center gap-4 text-sm font-medium text-slate-500">
                  <span class="font-bold text-slate-900">{featuredPost.authorName}</span>
                  <span class="w-1 h-1 bg-slate-300 rounded-full" />
                  <span>
                    {new Date(featuredPost.publishedAt).toLocaleDateString('en-AE', {
                      month: 'long',
                      year: 'numeric',
                    })}
                  </span>
                </div>
              </div>
            </div>
          </a>
        )
      }

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-10">
        {
          remainingPosts.map((post) => (
            <article class="group bg-white rounded-3xl overflow-hidden shadow-md hover:shadow-xl transition-all border border-slate-100 flex flex-col">
              <a href={`/blog/${post.slug.current}`} class="block aspect-[16/10] overflow-hidden">
                <img
                  src={urlFor(post.mainImage).width(600).height(400).url()}
                  alt={post.mainImage.alt}
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                />
              </a>
              <div class="p-8 flex flex-col flex-grow">
                <time class="text-xs font-bold text-blue-600 uppercase tracking-widest mb-4">
                  {new Date(post.publishedAt).toLocaleDateString('en-AE', {
                    month: 'short',
                    day: 'numeric',
                  })}
                </time>
                <h3 class="text-xl font-bold text-slate-900 mb-4 group-hover:text-blue-600 transition-colors">
                  <a href={`/blog/${post.slug.current}`}>{post.title}</a>
                </h3>
                <p class="text-slate-600 text-sm line-clamp-2 mb-6">{post.metaDescription}</p>
                <div class="mt-auto pt-6 border-t border-slate-50 flex justify-between items-center">
                  <span class="text-xs font-semibold text-slate-400">By {post.authorName}</span>
                  <span class="text-blue-600 font-bold text-sm group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">
                    Read More →
                  </span>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
