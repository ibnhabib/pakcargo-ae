---
import '../styles/global.css';
import { sanityClient } from "sanity:client";
import PriceGrid from "../components/PriceGrid.astro";
import ServiceSection from "../components/ServiceSection.astro";
import Hero from "../components/Hero.astro";
import WhyChooseUs from "../components/WhyChooseUs.astro";
import PartnerLogos from "../components/PartnerLogos.astro";

// 1. Fetch data
const services = await sanityClient.fetch(`*[_type == "service"] | order(_createdAt asc)`);
const rates = await sanityClient.fetch(`*[_type == "rateCard"] | order(pricePerKg asc)`);

// Fetch Global Partners
const globalPartners = await sanityClient.fetch(`*[_type == "partner" && type == "global"]`);
// Fetch Local Partners
const localPartners = await sanityClient.fetch(`*[_type == "partner" && type == "local"]`);

const trustData = await sanityClient.fetch(`*[_type == "trustPoints"][0]`);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>PakCargo.ae | Reliable Door-to-Door Cargo Dubai to Pakistan</title>
	</head>
	<body class="bg-slate-50 min-h-screen font-sans">
		
		<Hero />

		<main>
			<ServiceSection services={services} />
			
			<PartnerLogos globalPartners={globalPartners} localPartners={localPartners} />

			{trustData && <WhyChooseUs data={trustData} />}

			<section id="rates" class="py-10">
				<PriceGrid rates={rates} />
			</section>
		</main>

		<footer class="bg-slate-900 text-slate-400 py-10 text-center border-t border-slate-800 mt-20">
			<p class="text-sm uppercase tracking-widest">&copy; 2026 PakCargo.ae | Pakistan Cargo Services</p>
		</footer>

		<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LogisticsCompany",
  "name": "PakCargo.ae",
  "url": "https://pakcargo.ae",
  "logo": "https://pakcargo.ae/favicon.svg",
  "image": "https://pakcargo.ae/og-image.jpg",
  "telephone": "+971XXXXXXXXX",
  "priceRange": "$$",
  "description": "Premium door-to-door cargo and courier services from UAE to Pakistan. Utilizing global networks like DHL/FedEx and domestic leaders like TCS/Leopards.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Your Office Address Here",
    "addressLocality": "Dubai",
    "addressRegion": "Dubai",
    "addressCountry": "AE"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "25.2048",
    "longitude": "55.2708"
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
      "opens": "09:00",
      "closes": "21:00"
    }
  ],
  "sameAs": [
    "https://www.facebook.com/your-page",
    "https://www.instagram.com/your-page"
  ],
  "knowsAbout": ["Air Freight", "Sea Cargo", "Door to Door Delivery", "Customs Clearance"],
  "areaServed": [
    { "@type": "Country", "name": "United Arab Emirates" },
    { "@type": "Country", "name": "Pakistan" }
  ],
  "memberOf": [
    { "@type": "Organization", "name": "TCS Express Network" },
    { "@type": "Organization", "name": "Leopards Courier Service Network" }
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Cargo & Courier Services",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "International Document Delivery",
          "description": "Express air courier via DHL & FedEx networks for urgent documents."
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Door to Door Cargo to Pakistan",
          "description": "Comprehensive sea and air cargo delivery to all cities in Pakistan via Leopards & TCS."
        }
      }
    ]
  }
}
</script>
	</body>
</html>