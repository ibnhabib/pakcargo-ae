---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogSection from "../components/BlogSection.astro";
import { sanityClient } from "sanity:client";
import { urlFor } from "../lib/sanity";
import PriceGrid from "../components/PriceGrid.astro";
import ServiceSection from "../components/ServiceSection.astro";
import Hero from "../components/Hero.astro";
import WhyChooseUs from "../components/WhyChooseUs.astro";
import PartnerLogos from "../components/PartnerLogos.astro";
import FaqSection from "../components/FaqSection.astro";
import { MapPin } from 'lucide-react';

// 1. Fetch data
const settings = await sanityClient.fetch(`*[_type == "siteSettings"][0]`);
const services = await sanityClient.fetch(`*[_type == "service"] | order(title asc)`);
const rates = await sanityClient.fetch(`*[_type == "rateCard"] | order(pricePerKg asc)`);

const homeData = await sanityClient.fetch(`*[_type == "homepage"][0]{
  ...,
  faqs[] {
    question,
    atomicAnswer,
    detailedAnswer,
    lastReviewed
  }
}`);

const globalPartners = await sanityClient.fetch(`*[_type == "partner" && type == "global"]`);
const localPartners = await sanityClient.fetch(`*[_type == "partner" && type == "local"]`);
const trustData = await sanityClient.fetch(`*[_type == "trustPoints"][0]`);

// 2. Dynamic Schema Logic
const serviceAreas = settings?.mainServiceAreas || [
  "Dubai", "Abu Dhabi", "Sharjah", "Ajman", 
  "Ras Al Khaimah", "Al Ain", "Fujairah", "Umm Al Quwain"
];

const businessSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": "https://pakcargo.ae/#organization",
      "name": settings?.businessName || "PakCargo.ae",
      "url": "https://pakcargo.ae",
      "logo": "https://pakcargo.ae/favicon.svg",
      "image": settings?.ogImage ? urlFor(settings.ogImage).width(1200).url() : "https://pakcargo.ae/og-image.jpg",
      "telephone": settings?.phone || "+971XXXXXXXXX",
      "priceRange": "AED",
      "description": settings?.description,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Dubai",
        "addressRegion": "Dubai",
        "addressCountry": "AE"
      },
      "areaServed": [
        ...serviceAreas.map(city => ({ "@type": "City", "name": city })),
        { "@type": "Country", "name": "Pakistan" }
      ],
      // This pulls directly from your 'Core Business Keywords' in Sanity
      "knowsAbout": settings?.keywords || [
        "pakistan cargo", "pak cargo", "cargo to pakistan", "air cargo to pakistan"
      ]
    }
  ]
};

const faqSchema = homeData?.faqs ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": homeData.faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": { "@type": "Answer", "text": faq.atomicAnswer }
  }))
} : null;
---

<BaseLayout 
  title={settings?.title || "Pakistan Cargo from UAE | Sea & Air Pak Cargo Service - PakCargo.ae"}
  description={settings?.description}
>
  <script type="application/ld+json" set:html={JSON.stringify(businessSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}

  <Hero />

  <main>
    <ServiceSection services={services} />
    
    <PartnerLogos globalPartners={globalPartners} localPartners={localPartners} />
    {trustData && <WhyChooseUs data={trustData} />}

    <section id="rates" class="py-20 bg-white border-t border-slate-50">
      <div class="max-w-7xl mx-auto px-6 text-center">
        <h2 class="text-4xl font-black text-slate-900 mb-4 italic">Competitive Shipping Rates</h2>
        <p class="text-slate-600 text-lg mb-12">Updated <strong>pak cargo</strong> pricing for 2026 shipments.</p>
        <PriceGrid rates={rates} />
      </div>
    </section>

    <section class="py-24 bg-slate-50 border-y border-slate-100">
      <div class="max-w-6xl mx-auto px-6">
        <div class="flex flex-col md:flex-row justify-between items-center mb-16 gap-8 text-center md:text-left">
          <div class="max-w-2xl">
            <h2 class="text-3xl md:text-6xl font-black text-slate-900 mb-6 leading-tight italic">
              Door-to-Door Pickup <br/>Across the <span class="text-blue-600 text-nowrap underline decoration-blue-200 underline-offset-8">Entire UAE</span>
            </h2>
            <p class="text-xl text-slate-600 leading-relaxed">
              We provide professional <strong>pakistan cargo</strong> solutions with free home pickup service from every Emirate. Our logistics network is built for speed and safety.
            </p>
          </div>
          <div class="bg-white p-6 rounded-[2rem] shadow-xl shadow-blue-900/5 border border-blue-100 flex flex-col items-center">
             <div class="bg-blue-600 text-white p-4 rounded-2xl mb-4 shadow-lg">
                <MapPin size={32} />
             </div>
             <span class="text-slate-900 font-black text-2xl">{serviceAreas.length} Emirates</span>
             <span class="text-slate-400 font-medium">Daily Coverage</span>
          </div>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          {serviceAreas.map((area) => (
            <div class="group relative p-8 bg-white rounded-3xl border border-slate-200 shadow-sm hover:border-blue-500 hover:shadow-2xl hover:shadow-blue-500/10 transition-all duration-300 overflow-hidden text-center">
              <div class="absolute top-0 right-0 p-3 opacity-10 group-hover:opacity-100 transition-opacity">
                 <MapPin size={20} class="text-blue-600" />
              </div>
              <span class="block text-blue-600 text-xs font-black uppercase tracking-widest mb-3">Service Point</span>
              <span class="text-2xl font-black text-slate-900">{area}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <BlogSection />

    {homeData?.faqs && (
      <div class="bg-white py-24">
        <div class="max-w-4xl mx-auto px-6">
          <div class="text-center mb-16">
            <h2 class="text-4xl font-black text-slate-900 mb-4">Logistics Intelligence</h2>
            <p class="text-slate-500 text-lg italic">Essential info for your next <strong>pakistan cargo</strong> shipment.</p>
          </div>
          <FaqSection faqs={homeData.faqs} />
        </div>
      </div>
    )}
<!-- call to action start -- > 

    <section class="py-24 bg-slate-900 text-white relative overflow-hidden rounded-[3rem] mx-6 mb-12 shadow-2xl">
      <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
        <h2 class="text-4xl md:text-7xl font-black mb-8 tracking-tighter italic">Ready to Ship?</h2>
        <p class="text-slate-400 text-xl mb-12 max-w-2xl mx-auto">
           Get the most reliable <strong>door-to-door cargo to pakistan</strong> service. Our team is standing by in Dubai to assist you.
        </p>

        <div class="flex flex-col sm:flex-row justify-center items-center gap-6">
          <a href={`https://wa.me/${settings?.ctaValue}`} class="w-full sm:w-auto px-12 py-5 bg-green-600 hover:bg-green-700 text-white font-bold rounded-2xl transition-all text-xl shadow-xl shadow-green-900/40">
            WhatsApp Estimate
          </a>
          <a href={`tel:${settings?.phone}`} class="w-full sm:w-auto px-12 py-5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-2xl transition-all text-xl shadow-xl shadow-blue-900/40">
            Call Specialist
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>