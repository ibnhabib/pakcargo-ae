---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogSection from "../components/BlogSection.astro";
import { sanityClient } from "sanity:client";
import { urlFor } from "../lib/sanity";
import PriceGrid from "../components/PriceGrid.astro";
import ServiceSection from "../components/ServiceSection.astro";
import Hero from "../components/Hero.astro";
import WhyChooseUs from "../components/WhyChooseUs.astro";
import PartnerLogos from "../components/PartnerLogos.astro";
import FaqSection from "../components/FaqSection.astro"; // Import the component

// 1. Fetch data
const settings = await sanityClient.fetch(`*[_type == "siteSettings"][0]`);
const services = await sanityClient.fetch(`*[_type == "service"] | order(_createdAt asc)`);
const rates = await sanityClient.fetch(`*[_type == "rateCard"] | order(pricePerKg asc)`);

// Fetch Homepage Specific Data (Including your new FAQs)
const homeData = await sanityClient.fetch(`*[_type == "homepage"][0]{
  ...,
  faqs[] {
    question,
    atomicAnswer,
    detailedAnswer,
    lastReviewed,
    targetEntity
  }
}`);

// Fetch Partners
const globalPartners = await sanityClient.fetch(`*[_type == "partner" && type == "global"]`);
const localPartners = await sanityClient.fetch(`*[_type == "partner" && type == "local"]`);
const trustData = await sanityClient.fetch(`*[_type == "trustPoints"][0]`);

// 2. business Schema
const businessSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": "https://pakcargo.ae/#organization",
      "name": "PakCargo.ae",
      "url": "https://pakcargo.ae",
      "logo": "https://pakcargo.ae/favicon.svg",
      "image": settings?.ogImage ? urlFor(settings.ogImage).width(1200).url() : "https://pakcargo.ae/og-image.jpg",
      "telephone": settings?.phone || "+971XXXXXXXXX",
      "priceRange": "AED",
      "description": "Reliable door-to-door pak cargo services from UAE to Pakistan. Get cheap rates for sea and air cargo to Pakistan with free home pickup in Dubai, Abu Dhabi, and Sharjah. Professional pakistan cargo delivery to Karachi, Lahore, and all cities via TCS.",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Dubai",
        "addressRegion": "Dubai",
        "addressCountry": "AE"
        // Operating as a Service-Area Business (SAB): Street address is hidden to prevent unwanted walk-ins
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "25.2048",
        "longitude": "55.2708"
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
          "opens": "09:00",
          "closes": "17:00"
        }
      ],
      "knowsAbout": [
       {
    "@type": "Thing",
    "name": "Freight Forwarding",
    "sameAs": "https://en.wikipedia.org/wiki/Freight_forwarding"
  },
  {
    "@type": "Thing",
    "name": "Logistics in Dubai",
    "sameAs": "https://en.wikipedia.org/wiki/Transport_in_Dubai"
  },
  {
    "@type": "Thing",
    "name": "Shipping to Pakistan",
    "sameAs": "https://en.wikipedia.org/wiki/Pakistan%E2%80%93United_Arab_Emirates_relations"
  },
  {
    "@type": "Thing",
    "name": "Jebel Ali Port",
    "sameAs": "https://en.wikipedia.org/wiki/Jebel_Ali_Port"
  },
        "pakistan cargo",
        "pak cargo",
        "cargo to pakistan",
        "air cargo to pakistan",
        "cargo dubai to pakistan",
        "pak cargo service",
        "pakistan cargo dubai",
        "pak cargo near me",
        "door to door cargo pickup",
        "cheap cargo rates to pakistan",
      ],
      "areaServed": [
        { "@type": "City", "name": "Dubai" },
        { "@type": "City", "name": "Abu Dhabi" },
        { "@type": "City", "name": "Sharjah" },
        { "@type": "City", "name": "Ajman" },
        { "@type": "City", "name": "Al Ain" },
        { "@type": "City", "name": "Ras Al Khaimah" },
        { "@type": "Country", "name": "Pakistan" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://pakcargo.ae/#organization",
      "name": "PakCargo.ae",
      "url": "https://pakcargo.ae",
      "logo": "https://pakcargo.ae/favicon.svg",
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": settings?.phone || "+971XXXXXXXXX",
        "contactType": "customer service",
        "areaServed": ["AE", "PK"],
        "availableLanguage": ["English", "Urdu", "Hindi"]
      }
    }
  ]
};

// 3. Dynamic FAQ Schema for AI Overviews
const faqSchema = homeData?.faqs ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": homeData.faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.atomicAnswer
    }
  }))
} : null;
---

<BaseLayout 
  title={settings?.title || "Pakistan Cargo from Dubai | Best Pak Cargo Service - PakCargo.ae"}
  description={settings?.description || "Leading pakistan cargo service from Dubai. We offer air and sea pak cargo to pakistan with secure door-to-door delivery."}
>
  <script type="application/ld+json" set:html={JSON.stringify(businessSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}

  <Hero />

  <main>
    <ServiceSection services={services} />
    
    <PartnerLogos globalPartners={globalPartners} localPartners={localPartners} />
    
    {trustData && <WhyChooseUs data={trustData} />}

    <section id="rates" class="py-10">
      <PriceGrid rates={rates} />
    </section>

    <BlogSection />

    {homeData?.faqs && homeData.faqs.length > 0 && (
      <div class="bg-slate-50 py-10 border-t border-slate-100">
        <div class="max-w-7xl mx-auto px-6">
          <FaqSection faqs={homeData.faqs} />
        </div>
      </div>
    )}

    <section class="py-20 bg-slate-900 text-white">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">Ready to Ship with the Best Pak Cargo Service?</h2>
        <p class="text-slate-400 text-lg mb-10 max-w-2xl mx-auto">
          Get a fast quote for <strong>door-to-door cargo to pakistan</strong>. 
          Contact our Dubai team directly via WhatsApp or Phone for the best rates.
        </p>

        <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
          <a 
            href={`https://wa.me/${settings?.ctaValue}`} 
            class="w-full sm:w-auto inline-flex justify-center items-center px-10 py-4 bg-green-600 hover:bg-green-700 text-white font-bold rounded-lg transition-all text-lg shadow-lg shadow-green-900/20"
          >
            <svg class="w-6 h-6 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01"/></svg>
            WhatsApp Now
          </a>
          <a 
            href={`tel:${settings?.phone}`} 
            class="w-full sm:w-auto inline-flex justify-center items-center px-10 py-4 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-lg transition-all text-lg"
          >
            Call Specialist
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>